# Environment variables template
# Copy to .env and fill in your keys

# App Settings
APP_ENV=development
APP_LOG_LEVEL=INFO
# Preferred runtime DB override variable. APP_DB_PATH is still accepted as a compatibility alias.
DB_PATH=data/cryptoai.db
# Preferred runtime mode variables. APP_RUNTIME_MODE / APP_ALLOW_LIVE_ORDERS are compatibility aliases.
RUNTIME_MODE=paper
ALLOW_LIVE_ORDERS=false
LOW_RESOURCE_MODE=false
LANGUAGE=zh

# Exchange
EXCHANGE_PROVIDER=okx
EXCHANGE_PROXY_URL=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=
GLASSNODE_API_BASE=https://api.glassnode.com/v1/metrics
COINMETRICS_API_KEY=
COINMETRICS_API_BASE=https://api.coinmetrics.io/v4
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
FEISHU_CRITICAL_WEBHOOK_URL=
FEISHU_CRITICAL_WEBHOOK_SECRET=
LUNARCRUSH_API_KEY=
JIN10_URL=https://www.jin10.com/
AB_TESTING_ENABLED=false
AB_TESTING_CHALLENGER_MODEL_PATH=data/models/xgboost_challenger.json
AB_TESTING_CHALLENGER_ALLOCATION_PCT=0.10
AB_TESTING_EXECUTE_CHALLENGER_LIVE=false
XGBOOST_NUM_BOOST_ROUND=200
XGBOOST_NTHREAD=0
TRAINING_DATASET_LIMIT_1H=2000
TRAINING_DATASET_LIMIT_4H=1000
TRAINING_DATASET_LIMIT_1D=400
FAST_ALPHA_TRAINING_ENABLED=true
FAST_ALPHA_TRAINING_HORIZON_HOURS=6
FAST_ALPHA_LABEL_MIN_ABS_NET_RETURN_PCT=0.20
EXECUTION_SYMBOL_MIN_SAMPLES=8
EXECUTION_SYMBOL_ACCURACY_FLOOR_PCT=45
LIVE_MIN_CLOSED_TRADES=50
LIVE_MIN_PREDICTION_EVAL_COUNT=100
LIVE_MIN_XGBOOST_ACCURACY_PCT=55
LIVE_MIN_FUSION_ACCURACY_PCT=52
LIVE_MIN_HOLDOUT_ACCURACY_PCT=55
LIVE_MIN_TOTAL_REALIZED_PNL=0
LIVE_MAX_DRAWDOWN_PCT=5
LIVE_MAX_RESEARCH_FALLBACK_RATIO_PCT=10

# Paper validation helpers
NEAR_MISS_SHADOW_ENABLED=true
PAPER_CANARY_ENABLED=false
PAPER_CANARY_POSITION_SCALE=0.10
PAPER_CANARY_XGBOOST_GAP_PCT=0.10
PAPER_CANARY_FINAL_SCORE_GAP_PCT=0.12
PAPER_CANARY_MIN_REVIEW_SCORE=0.20
PAPER_CANARY_SOFT_ENABLED=false
PAPER_CANARY_OFFENSIVE_ENABLED=false
EXTREME_FEAR_CONSERVATIVE_ENABLED=true
EXTREME_FEAR_CONSERVATIVE_XGBOOST_BONUS_PCT=0.08
EXTREME_FEAR_CONSERVATIVE_FINAL_SCORE_BONUS=0.10
EXTREME_FEAR_CONSERVATIVE_LIQUIDITY_BONUS_RATIO=0.15
EXTREME_FEAR_CONSERVATIVE_POSITION_SCALE=0.25
EXCHANGE_MAX_ACTIVE_SYMBOLS=2
EXCHANGE_MARKET_DATA_RETRY_COUNT=2
EXCHANGE_MARKET_DATA_RETRY_DELAY_SECONDS=0.5

# LLM API Keys
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# Runtime loop cadence
ANALYSIS_INTERVAL_SECONDS=1800
ENTRY_SCAN_INTERVAL_SECONDS=300
FAST_ALPHA_ENABLED=true
FAST_ALPHA_ENTRY_SCAN_INTERVAL_SECONDS=300
FAST_ALPHA_MIN_PROBABILITY_PCT=0.58
FAST_ALPHA_ETH_MIN_PROBABILITY_PCT=0.54
FAST_ALPHA_MIN_FINAL_SCORE=0.54
FAST_ALPHA_MIN_REVIEW_SCORE=0.12
FAST_ALPHA_CLOSE_OVERRIDE_MIN_REVIEW_SCORE=-0.45
FAST_ALPHA_MAX_XGBOOST_GAP_PCT=0.20
FAST_ALPHA_MAX_FINAL_SCORE_GAP_PCT=0.10
FAST_ALPHA_POSITION_SCALE=0.35
FAST_ALPHA_FIXED_STOP_LOSS_PCT=0.018
FAST_ALPHA_MAX_HOLD_HOURS=6
FAST_ALPHA_DE_RISK_HOURS=1.0
FAST_ALPHA_DE_RISK_PNL_RATIO=0.004
FAST_ALPHA_PORTFOLIO_HEAT_OVERRIDE_ENABLED=true
FAST_ALPHA_PORTFOLIO_HEAT_OVERRIDE_SCALE=0.50
FAST_ALPHA_LIQUIDITY_OVERRIDE_ENABLED=true
FAST_ALPHA_LIQUIDITY_FLOOR_RATIO=0.25
